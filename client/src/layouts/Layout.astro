---
import { ClientRouter } from "astro:transitions";
import "../index.css";
import Nav from "../components/Nav";
import Footer from "../components/Footer";
import GradientBackground from "../components/GradientBackground";
import CustomCursor from "../components/CustomCursor";
import { CONTACT, TAGLINE } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Damn — Damn Good Websites",
  description = "Damn — custom websites, designed and built damn good. Tell us what you want; we build it to spec.",
} = Astro.props;

// Absolute URLs for canonical + social scrapers (need full origin, not paths).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/og.png", Astro.site).href;

// Organization schema — site-wide, helps Google's knowledge panel / rich results.
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Damn",
  url: Astro.site?.href,
  logo: new URL("/logo.png", Astro.site).href,
  description: TAGLINE,
  email: CONTACT.email,
  sameAs: [CONTACT.instagram, CONTACT.github],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0A0B" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Damn" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <ClientRouter />
  </head>
  <body>
    <!-- raf/cursor effects: non-critical, hydrate when idle.
         transition:persist keeps them mounted across navigations so the raf
         loop / cursor state don't restart on every page swap. -->
    <GradientBackground client:idle transition:persist />
    <CustomCursor client:idle transition:persist />
    <Nav client:load transition:persist />
    <slot />
    <Footer />
  </body>
</html>
